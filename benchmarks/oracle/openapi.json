    "/parser": {
      "post": {
        "tags": [
          "C – False-merge challenge"
        ],
        "summary": "Parse structured content",
        "description": "BUG-004 — JSON parser internal crash (triggered when format=='json' and\n           content contains '{{crash}}').\nBUG-005 — XML parser internal crash  (triggered when format=='xml' and\n           content contains '<crash/>').\n\nBoth return HTTP 500 JSON from the same endpoint.\nA coarse deduplicator sees: (exit=crash, kind=500, class=json, endpoint=POST /parser)\nand will MERGE them into one cluster — a false merge.",
        "operationId": "parse_content_parser_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ParseRequest"

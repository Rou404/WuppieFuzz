    "/reports/generate": {
      "post": {
        "tags": [
          "K – Same-endpoint distinct bugs"
        ],
        "summary": "Generate a report",
        "description": "BUG-013 — report type 'financial_audit' triggers an integer overflow in the\n           accounting sub-module.\nBUG-014 — include_pii=True with report_type='gdpr_export' triggers a\n           null-pointer in the anonymisation layer.\n\nBoth return HTTP 500 JSON from the same endpoint.\nA coarse deduplicator (keying on endpoint + status + response class) will\nMERGE BUG-013 and BUG-014 — a false merge similar to the C case but on a\ndifferent endpoint, giving the benchmark more statistical signal.",
        "operationId": "generate_report_reports_generate_post",
        "requestBody": {

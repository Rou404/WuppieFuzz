            "description": "Dividend"
          },
          {
            "name": "denominator",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "description": "Divisor",
              "title": "Denominator"
            },
            "description": "Divisor"
          }
        ],

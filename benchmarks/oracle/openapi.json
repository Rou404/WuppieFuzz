    "/flaky/{resource_id}": {
      "get": {
        "tags": [
          "I – Deterministic path bug"
        ],
        "summary": "Fetch a resource (deterministically fails for resource_id % 7 == 0)",
        "description": "BUG-011 — crashes when resource_id % 7 == 0 (i.e. 0, 7, 14, 21, …).\nAppears 'flaky' to a fuzzer that doesn't understand the pattern, but is\nfully deterministic — useful for measuring how replay-based deduplication\nhandles inputs that seem intermittent but are actually stable.",
        "operationId": "flaky_resource_flaky__resource_id__get",
        "parameters": [
          {
